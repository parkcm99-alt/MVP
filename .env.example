# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for Supabase Realtime + persistence. Leave empty to run in MOCK MODE.
NEXT_PUBLIC_SUPABASE_URL=
# Must be the Supabase anon JWT from Project Settings → API.
# Never put ANTHROPIC_API_KEY, OpenAI keys, or service role keys in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only (admin operations)

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Server-only. Never expose this with a NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=

# Cost guard: keep false by default. Live Claude calls require true + API key.
ENABLE_LIVE_LLM=false

# Global default model. Defaults to claude-sonnet-4-20250514 when left empty.
# If a configured model is not found, the server retries this stable default once.
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Per-agent model overrides (optional) ──────────────────────────────────────
# Each role resolves its model via: CLAUDE_<ROLE>_MODEL → CLAUDE_MODEL → default.
# Leave empty to inherit the global CLAUDE_MODEL above.
#
# Cost optimisation example:
#   CLAUDE_REVIEWER_MODEL=claude-haiku-4-20250514
#   CLAUDE_QA_MODEL=claude-haiku-4-20250514
#
CLAUDE_PLANNER_MODEL=
CLAUDE_ARCHITECT_MODEL=
CLAUDE_DEVELOPER_MODEL=
CLAUDE_REVIEWER_MODEL=
CLAUDE_QA_MODEL=
