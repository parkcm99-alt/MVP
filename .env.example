# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for Supabase Realtime + persistence. Leave empty to run in MOCK MODE.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only (admin operations)

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Required for Phase 4: real LLM agent responses.
# ⚠️  Server-only — never use NEXT_PUBLIC_ prefix here.
# Leave empty (or commented out) to keep mock simulation running without cost.
ANTHROPIC_API_KEY=

# Default model for future Claude agent calls.
# Options: claude-sonnet-4-6 | claude-opus-4-5 | claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6
