# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for Supabase Realtime + persistence. Leave empty to run in MOCK MODE.
NEXT_PUBLIC_SUPABASE_URL=
# Use the browser-safe publishable key (sb_publishable_...) or legacy anon JWT
# from Dashboard → Project Settings → API Keys.
# Never put ANTHROPIC_API_KEY, OpenAI keys, or service role keys in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only service-role JWT or sb_secret_ key

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Server-only. Never expose this with a NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=

# Cost guard: keep false by default. Live Claude calls require true + API key.
ENABLE_LIVE_LLM=false

# Global default model. Falls back to claude-sonnet-4-6 when left empty.
# If a configured model is not found, the server retries this stable default once.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional Claude request timeout for server routes.
# Sonnet role prompts may need more than 8s in production; clamped to 5000-25000ms.
CLAUDE_TIMEOUT_MS=15000

# ── Per-agent model overrides ─────────────────────────────────────────────────
# Each role resolves its model via:
# CLAUDE_<ROLE>_MODEL → built-in role default → CLAUDE_MODEL → default.
# Planner / Architect / Developer → Sonnet (quality)
# Reviewer / QA → Haiku by default (cost optimisation)
CLAUDE_PLANNER_MODEL=claude-sonnet-4-6
CLAUDE_ARCHITECT_MODEL=claude-sonnet-4-6
CLAUDE_DEVELOPER_MODEL=claude-sonnet-4-6
CLAUDE_REVIEWER_MODEL=claude-haiku-4-5-20251001
CLAUDE_QA_MODEL=claude-haiku-4-5-20251001
# Optional future Secretary Claude model. Secretary is client-state based in v1.
CLAUDE_SECRETARY_MODEL=claude-haiku-4-5-20251001

# ── Secretary notifications (server-only) ─────────────────────────────────────
# Keep false unless webhook/token values are configured in Vercel as Sensitive.
ENABLE_SLACK_NOTIFY=false
SLACK_WEBHOOK_URL=
ENABLE_TELEGRAM_NOTIFY=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google OAuth scaffolding (server-only) ────────────────────────────────────
# GOOGLE_CLIENT_SECRET must never use NEXT_PUBLIC_.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
