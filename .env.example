# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for Supabase Realtime + persistence. Leave empty to run in MOCK MODE.
NEXT_PUBLIC_SUPABASE_URL=
# Use the Supabase legacy anon JWT (or newer sb_publishable_ public key).
# Never put ANTHROPIC_API_KEY, OpenAI keys, or service role keys in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, preferred for route-handler trace inserts. Never use NEXT_PUBLIC_.
# If omitted, the server falls back to anon and warns missing_service_role_key.
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
# Server-only. Never expose this with a NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=

# Cost guard: keep false by default. Live Claude calls require true + API key.
ENABLE_LIVE_LLM=false

# Optional. Defaults to claude-sonnet-4-20250514 in server code when left empty.
# If a configured model is not found, the server retries this stable default once.
CLAUDE_MODEL=
